<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/haru_brown"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Franja roja de urgencia -->
        <View
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="@color/haru_brown"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Nombre mascota + emoji -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐾"
                    android:textSize="24sp"
                    android:layout_marginEnd="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvNombreMascotaAlerta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/haru_brown"/>

                    <TextView
                        android:id="@+id/tvDuenoAlerta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/haru_text_secondary"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <!-- Chip PERDIDA -->
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERDIDA"
                    android:textSize="10sp"
                    android:textColor="@color/haru_white"
                    app:chipBackgroundColor="@color/haru_brown"
                    android:clickable="false"
                    style="@style/Widget.Material3.Chip.Assist"/>

            </LinearLayout>

            <!-- Mensaje adicional -->
            <TextView
                android:id="@+id/tvMensajeAlerta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/haru_text_primary"
                android:layout_marginBottom="12dp"/>

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/haru_teal_light"
                android:layout_marginBottom="12dp"/>

            <!-- Pie: fecha + teléfono dueño -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha"
                        android:textSize="11sp"
                        android:textColor="@color/haru_grey"/>

                    <TextView
                        android:id="@+id/tvFechaAlerta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/haru_text_primary"/>

                </LinearLayout>

                <!-- Botón llamar al dueño -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLlamarDueno"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Llamar"
                    android:textSize="12sp"
                    android:textColor="@color/haru_teal_dark"
                    app:strokeColor="@color/haru_teal"
                    app:cornerRadius="8dp"
                    app:icon="@android:drawable/ic_menu_call"
                    app:iconTint="@color/haru_teal"
                    app:iconSize="16dp"/>

            </LinearLayout>

            <!-- Botón resolver: solo visible si la alerta es del usuario -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMascotaEncontrada"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="✅ Mascota encontrada"
                android:textSize="13sp"
                android:backgroundTint="@color/haru_teal"
                android:textColor="@color/haru_white"
                app:cornerRadius="8dp"
                android:visibility="gone"/>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>