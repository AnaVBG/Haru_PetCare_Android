<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/haru_brown"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- ── CABECERA: foto + nombre + chip ──────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Avatar con foto o inicial -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="12dp">

                <!-- Fondo circular marrón (fallback) -->
                <View
                    android:id="@+id/viewFondoAvatarAlerta"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_avatar_alerta"/>

                <!-- Inicial de la mascota (fallback) -->
                <TextView
                    android:id="@+id/tvInicialMascotaAlerta"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:textColor="@color/haru_white"/>

                <!-- Foto real de la mascota cargada con Glide -->
                <ImageView
                    android:id="@+id/ivFotoMascotaAlerta"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerCrop"
                    android:clipToOutline="true"
                    android:background="@drawable/bg_avatar_alerta"
                    android:contentDescription="Foto de la mascota"
                    android:visibility="gone"/>

            </FrameLayout>

            <!-- Nombre mascota + dueño -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNombreMascotaAlerta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/haru_brown"/>

                <TextView
                    android:id="@+id/tvDuenoAlerta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/haru_text_secondary"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERDIDA"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/haru_white"
                android:background="@drawable/bg_badge_perdida"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>

        <!-- ── MENSAJE ADICIONAL ───────────────────────────────────── -->
        <TextView
            android:id="@+id/tvMensajeAlerta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/haru_text_primary"
            android:layout_marginBottom="10dp"/>

        <!-- ── SEPARADOR ──────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/haru_teal_light"
            android:layout_marginBottom="10dp"/>

        <!-- ── PIE: fecha + botón llamar ─────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha"
                    android:textSize="11sp"
                    android:textColor="@color/haru_grey"/>

                <TextView
                    android:id="@+id/tvFechaAlerta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/haru_text_primary"/>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLlamarDueno"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Llamar"
                android:textSize="12sp"
                android:textColor="@color/haru_teal_dark"
                app:strokeColor="@color/haru_teal"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_bell"
                app:iconTint="@color/haru_teal"
                app:iconSize="16dp"/>

        </LinearLayout>

        <!-- ── BOTÓN RESOLVER (solo si es tu alerta) ─────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMascotaEncontrada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Mascota encontrada"
            android:textSize="13sp"
            android:backgroundTint="@color/haru_teal"
            android:textColor="@color/haru_white"
            app:cornerRadius="8dp"
            android:visibility="gone"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>