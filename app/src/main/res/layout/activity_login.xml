<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_login_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ══════════════════════════════════════
             HEADER  ·  logo + nombre de la app
             ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="56dp"
            android:paddingBottom="40dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp">

            <!-- Logo flotante sobre círculo blanco con sombra -->
            <androidx.cardview.widget.CardView
                android:layout_width="96dp"
                android:layout_height="96dp"
                app:cardCornerRadius="48dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="@color/haru_white"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@mipmap/ic_launcher_round"
                    android:padding="8dp"
                    android:contentDescription="Logo Haru"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HARU"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="@color/haru_white"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Petcare"
                android:textSize="18sp"
                android:textColor="#AAFFFFFF"
                android:letterSpacing="0.05"/>

        </LinearLayout>

        <!-- ══════════════════════════════════════
             FORMULARIO  ·  tarjeta blanca con
             esquinas superiores redondeadas
             ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_login_form"
            android:paddingTop="36dp"
            android:paddingBottom="32dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp">

            <!-- Título bienvenida -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bienvenido de vuelta"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/haru_text_primary"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicia sesión para cuidar a tus mascotas"
                android:textSize="16sp"
                android:textColor="@color/haru_text_secondary"
                android:layout_marginBottom="28dp"/>

            <!-- Campo correo electrónico -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_email"
                    android:layout_marginEnd="10dp"
                    app:tint="@color/haru_teal"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Correo electrónico"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/haru_teal"
                    app:hintTextColor="@color/haru_teal_dark">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Campo contraseña -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_lock"
                    android:layout_marginEnd="10dp"
                    app:tint="@color/haru_teal"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Contraseña"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/haru_teal"
                    app:hintTextColor="@color/haru_teal_dark"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/haru_teal">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Botón principal: iniciar sesión -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Iniciar sesión"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/haru_teal"
                android:textColor="@color/haru_white"
                app:cornerRadius="26dp"
                app:elevation="3dp"/>

            <!-- Separador "o" -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/haru_grey"
                    android:alpha="0.5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  o  "
                    android:textColor="@color/haru_text_secondary"
                    android:textSize="13sp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/haru_grey"
                    android:alpha="0.5"/>
            </LinearLayout>

            <!-- Botón secundario: registrarse (borde teal) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIrARegistro"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="¿No tienes cuenta? Regístrate"
                android:textSize="14sp"
                android:textColor="@color/haru_teal_dark"
                app:strokeColor="@color/haru_teal"
                app:strokeWidth="1.5dp"
                app:cornerRadius="26dp"/>

            <!-- Barra de progreso (visible solo durante la carga) -->
            <ProgressBar
                android:id="@+id/progressBarLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:indeterminateTint="@color/haru_teal"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>