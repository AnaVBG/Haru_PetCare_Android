<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/haru_surface">

    <!-- Toolbar en marrón — color de emergencia -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/haru_brown"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarAlertas"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/haru_brown"
            app:title="Alertas de pérdida"
            app:titleTextColor="@color/haru_white"/>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ── BOTÓN DE EMERGENCIA ─────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/haru_brown"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚨"
                        android:textSize="48sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿Se ha perdido tu mascota?"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/haru_brown"
                        android:gravity="center"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pulsa el botón para alertar a los vecinos en un radio de 5 km"
                        android:textSize="13sp"
                        android:textColor="@color/haru_text_secondary"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmergencia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Activar alerta de pérdida"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:padding="14dp"
                        android:backgroundTint="@color/haru_brown"
                        android:textColor="@color/haru_white"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_bell"
                        app:iconTint="@color/haru_white"
                        app:iconGravity="textStart"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── ALERTAS ACTIVAS EN TU ZONA ─────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alertas activas en tu zona"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/haru_brown"
                android:layout_marginBottom="8dp"/>

            <ProgressBar
                android:id="@+id/progressBarAlertas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/haru_brown"
                android:visibility="gone"/>

            <!-- Estado vacío -->
            <LinearLayout
                android:id="@+id/layoutSinAlertas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="48sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No hay mascotas perdidas cerca"
                    android:textSize="15sp"
                    android:textColor="@color/haru_text_secondary"
                    android:gravity="center"/>

            </LinearLayout>

            <!-- Lista de alertas -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAlertas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="24dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>