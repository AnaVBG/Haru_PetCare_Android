<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/haru_surface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/haru_teal"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarMascotas"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/haru_teal"
            app:titleTextColor="@color/haru_white"/>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── SALUDO ────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/haru_teal"
                android:paddingHorizontal="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvSaludo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buenos días"
                    android:textSize="13sp"
                    android:textColor="#CCffffff"/>

                <TextView
                    android:id="@+id/tvNombreUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usuario"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/haru_white"/>

            </LinearLayout>

            <!-- ── PRÓXIMAS CITAS ─────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/haru_teal_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Próximas citas"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/haru_brown"
                        android:layout_marginBottom="8dp"/>

                    <!-- ProgressBar mientras carga las citas -->
                    <ProgressBar
                        android:id="@+id/progressBarCitasHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:indeterminateTint="@color/haru_teal"
                        android:visibility="gone"/>

                    <!-- Cita 1 -->
                    <LinearLayout
                        android:id="@+id/layoutCita1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="6dp"
                        android:visibility="gone">

                        <!-- Bloque de fecha -->
                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvCita1Dia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/haru_teal"/>

                            <TextView
                                android:id="@+id/tvCita1Mes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:textColor="@color/haru_grey"/>

                        </LinearLayout>

                        <!-- Barra divisora vertical -->
                        <View
                            android:layout_width="2dp"
                            android:layout_height="32dp"
                            android:layout_marginHorizontal="10dp"
                            android:background="@color/haru_teal_light"/>

                        <!-- Descripción -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvCita1Desc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/haru_text_primary"/>

                            <TextView
                                android:id="@+id/tvCita1Sub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="@color/haru_grey"/>

                        </LinearLayout>

                        <!-- Badge estado -->
                        <TextView
                            android:id="@+id/tvCita1Estado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:textSize="10sp"
                            android:background="@drawable/bg_badge_pendiente"
                            android:textColor="@color/haru_brown"/>

                    </LinearLayout>

                    <!-- Divisor entre citas -->
                    <View
                        android:id="@+id/dividerCitas"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/haru_teal_light"
                        android:visibility="gone"/>

                    <!-- Cita 2 -->
                    <LinearLayout
                        android:id="@+id/layoutCita2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="6dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvCita2Dia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/haru_teal"/>

                            <TextView
                                android:id="@+id/tvCita2Mes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:textColor="@color/haru_grey"/>

                        </LinearLayout>

                        <View
                            android:layout_width="2dp"
                            android:layout_height="32dp"
                            android:layout_marginHorizontal="10dp"
                            android:background="@color/haru_teal_light"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvCita2Desc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/haru_text_primary"/>

                            <TextView
                                android:id="@+id/tvCita2Sub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="@color/haru_grey"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvCita2Estado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:textSize="10sp"
                            android:background="@drawable/bg_badge_pendiente"
                            android:textColor="@color/haru_brown"/>

                    </LinearLayout>

                    <!-- Estado vacío: sin citas próximas -->
                    <TextView
                        android:id="@+id/tvSinCitas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No tienes citas próximas"
                        android:textSize="13sp"
                        android:textColor="@color/haru_grey"
                        android:gravity="center"
                        android:paddingVertical="8dp"
                        android:visibility="gone"/>

                    <!-- Enlace ver todas -->
                    <TextView
                        android:id="@+id/tvVerTodasCitas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="4dp"
                        android:text="Ver todas en Salud →"
                        android:textSize="12sp"
                        android:textColor="@color/haru_teal"
                        android:visibility="gone"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── ACCESOS RÁPIDOS ────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accesos rápidos"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/haru_brown"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="true">

                <!-- Salud -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAccesoSalud"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/haru_teal_light"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/iconAccesoSalud"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_heart_rate"
                            android:backgroundTint="#E0F5F5"
                            android:background="@drawable/bg_icon_rounded"
                            android:padding="6dp"
                            android:layout_marginBottom="6dp"
                            android:contentDescription="Salud"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Salud"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/haru_text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Historial y citas"
                            android:textSize="11sp"
                            android:textColor="@color/haru_grey"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Mapa -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAccesoMapa"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/haru_teal_light"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/iconAccesoMapa"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_map"
                            android:backgroundTint="#F8D7DA"
                            android:background="@drawable/bg_icon_rounded"
                            android:padding="6dp"
                            android:layout_marginBottom="6dp"
                            android:contentDescription="Mapa"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mapa"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/haru_text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Zona comunitaria"
                            android:textSize="11sp"
                            android:textColor="@color/haru_grey"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Alertas -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAccesoAlertas"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/haru_teal_light"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/iconAccesoAlertas"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_bell"
                            android:backgroundTint="#E9D5FF"
                            android:background="@drawable/bg_icon_rounded"
                            android:padding="6dp"
                            android:layout_marginBottom="6dp"
                            android:contentDescription="Alertas"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alertas"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/haru_text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Emergencias"
                            android:textSize="11sp"
                            android:textColor="@color/haru_grey"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Perfil -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAccesoPerfil"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/haru_teal_light"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/iconAccesoPerfil"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_user_circle"
                            android:backgroundTint="#F5F5F5"
                            android:background="@drawable/bg_icon_rounded"
                            android:padding="6dp"
                            android:layout_marginBottom="6dp"
                            android:contentDescription="Perfil"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mi perfil"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/haru_text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mis datos"
                            android:textSize="11sp"
                            android:textColor="@color/haru_grey"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- ── MIS MASCOTAS ───────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mis mascotas"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/haru_brown"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <ProgressBar
                android:id="@+id/progressBarMascotas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="48dp"
                android:indeterminateTint="@color/haru_teal"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/layoutSinMascotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="48dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐾"
                    android:textSize="64sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tvSinMascotas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aún no tienes mascotas registradas"
                    android:textSize="16sp"
                    android:textColor="@color/haru_text_secondary"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pulsa el botón + para añadir tu primera mascota"
                    android:textSize="13sp"
                    android:textColor="@color/haru_grey"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMascotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAnadirMascota"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/ic_plus"
        android:contentDescription="Añadir mascota"
        app:backgroundTint="@color/haru_brown"
        app:tint="@color/haru_white"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>