<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/haru_surface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/haru_teal"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarAddMascota"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/haru_teal"
            app:title="Nueva mascota"
            app:titleTextColor="@color/haru_white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/haru_white"/>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── FOTO ───────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/haru_teal_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Foto de la mascota"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/haru_brown"
                        android:layout_marginBottom="12dp"/>

                    <FrameLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_gravity="center_horizontal">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/ivFotoPreview"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:src="@drawable/ic_camera_placeholder"
                            android:background="@color/haru_teal_light"
                            app:civ_border_width="2dp"
                            app:civ_border_color="@color/haru_teal"/>

                        <com.google.android.material.floatingactionbutton.FloatingActionButton
                            android:id="@+id/fabSeleccionarFoto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|end"
                            android:src="@drawable/ic_plus"
                            app:fabSize="mini"
                            app:backgroundTint="@color/haru_brown"
                            app:tint="@color/haru_white"
                            android:contentDescription="Seleccionar foto"/>

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toca la foto para cambiarla"
                        android:textSize="14sp"
                        android:textColor="@color/haru_grey"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── DATOS ───────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/haru_teal_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Datos de la mascota"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/haru_brown"
                        android:layout_marginBottom="12dp"/>

                    <!-- Nombre -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNombreMascota"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Nombre *"
                        app:boxStrokeColor="@color/haru_teal"
                        app:hintTextColor="@color/haru_teal_dark">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNombreMascota"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="@color/haru_text_primary"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Especie -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEspecie"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Especie (Perro, Gato...) *"
                        app:boxStrokeColor="@color/haru_teal"
                        app:hintTextColor="@color/haru_teal_dark">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEspecie"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="@color/haru_text_primary"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Raza -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilRaza"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Raza (opcional)"
                        app:boxStrokeColor="@color/haru_teal"
                        app:hintTextColor="@color/haru_teal_dark">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRaza"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="@color/haru_text_primary"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Fecha nacimiento -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilFechaNacimiento"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Fecha de nacimiento *"
                        app:boxStrokeColor="@color/haru_teal"
                        app:hintTextColor="@color/haru_teal_dark"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_calendar_event"
                        app:endIconTint="@color/haru_teal">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFechaNacimiento"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:textColor="@color/haru_text_primary"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── BOTÓN GUARDAR ───────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarMascota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar mascota"
                android:textSize="18sp"
                android:padding="14dp"
                android:backgroundTint="@color/haru_teal"
                android:textColor="@color/haru_white"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_plus"
                app:iconTint="@color/haru_white"/>

            <ProgressBar
                android:id="@+id/progressBarAniadir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:indeterminateTint="@color/haru_teal"
                android:visibility="gone"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>