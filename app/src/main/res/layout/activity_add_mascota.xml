<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/haru_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarAddMascota"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/haru_teal"
            app:title="Nueva mascota"
            app:titleTextColor="@color/haru_white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/haru_white"/>

        <!-- Selector de foto -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/ivFotoMascota"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera"
                android:background="@color/haru_teal_light"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Foto de la mascota"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pulsa para añadir foto (opcional)"
                android:textSize="12sp"
                android:textColor="@color/haru_teal_dark"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNombreMascota"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre de la mascota"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="@color/haru_teal"
                app:hintTextColor="@color/haru_teal_dark">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombreMascota"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:imeOptions="actionNext"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEspecie"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Especie (Perro, Gato...)"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="@color/haru_teal"
                app:hintTextColor="@color/haru_teal_dark">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEspecie"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:imeOptions="actionNext"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRaza"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Raza (opcional)"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="@color/haru_teal"
                app:hintTextColor="@color/haru_teal_dark">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRaza"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:imeOptions="actionNext"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilFechaNacimiento"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fecha de nacimiento"
                android:layout_marginBottom="32dp"
                app:boxStrokeColor="@color/haru_teal"
                app:hintTextColor="@color/haru_teal_dark"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
                app:endIconTint="@color/haru_teal">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFechaNacimiento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarMascota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar mascota"
                android:textSize="16sp"
                android:padding="14dp"
                android:backgroundTint="@color/haru_teal"
                android:textColor="@color/haru_white"
                app:cornerRadius="12dp"/>

            <ProgressBar
                android:id="@+id/progressBarAniadir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:indeterminateTint="@color/haru_teal"
                android:visibility="gone"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>