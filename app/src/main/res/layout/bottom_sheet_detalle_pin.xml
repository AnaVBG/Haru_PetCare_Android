<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/haru_white">

    <!-- Handle visual del BottomSheet -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"
        android:background="@color/haru_grey"/>

    <!-- Ícono + tipo de pin -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <!--
            Contenedor circular con color de fondo dinámico (se setea
            por código en MapaFragment según el tipo del pin).
        -->
        <FrameLayout
            android:id="@+id/flIconoPin"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_pin_fuente"
            android:backgroundTint="@color/haru_teal_light">

            <ImageView
                android:id="@+id/ivIconoPin"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_pin_fuente"
                android:contentDescription="Tipo de pin"/>

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTipoPin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/haru_brown"/>

            <TextView
                android:id="@+id/tvUsuarioPin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/haru_text_secondary"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Descripción -->
    <TextView
        android:id="@+id/tvDescripcionPin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/haru_text_primary"
        android:lineSpacingExtra="3dp"
        android:layout_marginBottom="20dp"/>

    <!-- Botón borrar (solo visible si es del usuario) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBorrarPin"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Eliminar este pin"
        android:visibility="gone"
        app:strokeColor="#C0392B"
        android:textColor="#C0392B"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_pin_peligro"
        app:iconTint="#C0392B"
        app:iconSize="18dp"/>

</LinearLayout>