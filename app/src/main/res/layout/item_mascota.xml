<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/haru_teal_light"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Avatar -->
        <FrameLayout
            android:id="@+id/flAvatar"
            android:layout_width="56dp"
            android:layout_height="56dp">

            <View
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_avatar_circle"/>

            <TextView
                android:id="@+id/tvInicialMascota"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/haru_white"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/civFotoMascota"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:visibility="gone"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/haru_teal"/>

        </FrameLayout>

        <!-- Información -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvNombreMascota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/haru_brown"/>

            <TextView
                android:id="@+id/tvEspecieRaza"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/haru_teal_dark"
                android:layout_marginTop="2dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_person"
                    android:tint="@color/haru_grey"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="Dueño"/>

                <TextView
                    android:id="@+id/tvNombreDueno"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/haru_grey"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Flecha -->
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_chevron_right"
            android:tint="@color/haru_teal_light"
            android:contentDescription="Ver detalle"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>