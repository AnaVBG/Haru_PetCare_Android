<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/haru_teal_light"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!--
            Avatar: capas apiladas en un FrameLayout.
            Capa 1 (fondo): círculo teal con la inicial — siempre visible.
            Capa 2 (encima): CircleImageView con la foto real.
            Si no hay foto, la capa 2 es invisible y se ve la inicial.
        -->
        <FrameLayout
            android:id="@+id/flAvatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="16dp">

            <!-- Fondo circular teal con la inicial (fallback) -->
            <View
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_avatar_circle"/>

            <TextView
                android:id="@+id/tvInicialMascota"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/haru_white"/>

            <!--
                CircleImageView encima del fallback.
                Empieza invisible (GONE). El Adapter lo hace VISIBLE
                solo cuando Glide carga la imagen con éxito.
                El borde teal conecta visualmente con el fondo.
            -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/civFotoMascota"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:visibility="gone"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/haru_teal"/>

        </FrameLayout>

        <!-- Datos de la mascota -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreMascota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/haru_brown"/>

            <TextView
                android:id="@+id/tvEspecieMascota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/haru_teal_dark"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvRazaMascota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/haru_text_secondary"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Flecha -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="28sp"
            android:textColor="@color/haru_teal"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>