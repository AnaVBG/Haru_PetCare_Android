<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- El mapa ocupa toda la pantalla -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Panel superior flotante con título y leyenda -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/haru_teal_light"
        app:strokeWidth="1dp"
        app:layout_anchor="@id/mapFragment"
        app:layout_anchorGravity="top">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@color/haru_white">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mapa comunitario"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/haru_brown"
                android:layout_marginBottom="8dp"/>

            <!-- Leyenda de tipos de pin -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/haru_teal_light"
                    app:strokeWidth="1dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💧 Fuente"
                        android:textSize="11sp"
                        android:textColor="@color/haru_teal_dark"
                        android:gravity="center"
                        android:padding="6dp"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/haru_teal_light"
                    app:strokeWidth="1dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🗑️ Papelera"
                        android:textSize="11sp"
                        android:textColor="@color/haru_text_secondary"
                        android:gravity="center"
                        android:padding="6dp"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/haru_teal_light"
                    app:strokeWidth="1dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⚠️ Peligro"
                        android:textSize="11sp"
                        android:textColor="@color/haru_text_secondary"
                        android:gravity="center"
                        android:padding="6dp"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/haru_teal_light"
                    app:strokeWidth="1dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🌳 Parque"
                        android:textSize="11sp"
                        android:textColor="@color/haru_text_secondary"
                        android:gravity="center"
                        android:padding="6dp"/>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ProgressBar mientras carga los pines -->
    <ProgressBar
        android:id="@+id/progressBarMapa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/haru_teal"
        android:visibility="gone"/>

    <!-- FAB secundario: centrar en mi ubicación -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMiUbicacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="92dp"
        app:fabSize="mini"
        android:src="@drawable/ic_map"
        android:contentDescription="Mi ubicación"
        app:backgroundTint="@color/haru_teal"
        app:tint="@color/haru_white"/>

    <!-- FAB principal: añadir pin -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAnadirPin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/ic_plus"
        android:contentDescription="Añadir pin"
        app:backgroundTint="@color/haru_brown"
        app:tint="@color/haru_white"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>