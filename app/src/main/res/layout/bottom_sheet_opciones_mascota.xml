<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/haru_white">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"
        android:background="@color/haru_grey"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Añadir mascota a la clínica"
        android:textSize="21sp"
        android:textStyle="bold"
        android:textColor="@color/haru_brown"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVincularExistente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vincular dueño existente"
        android:textSize="18sp"
        android:padding="14dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/haru_teal"
        android:textColor="@color/haru_white"
        app:cornerRadius="12dp"
        app:icon="@android:drawable/ic_menu_search"
        app:iconTint="@color/haru_white"
        app:iconGravity="textStart"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCrearNuevo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crear dueño y mascota nuevos"
        android:textSize="18sp"
        android:padding="14dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/haru_brown"
        android:textColor="@color/haru_white"
        app:cornerRadius="12dp"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="@color/haru_white"
        app:iconGravity="textStart"/>

</LinearLayout>