<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Tirador del bottom sheet -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@color/haru_teal_light"
        android:backgroundTint="@color/haru_teal"/>

    <!-- Avatar + datos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <!-- Círculo con inicial -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="@color/haru_teal"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tvInicialAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/haru_white"/>

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvNombrePerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/haru_brown"/>

            <TextView
                android:id="@+id/tvEmailPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/haru_teal_dark"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvRolPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/haru_teal"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/haru_teal_light"
        android:layout_marginBottom="20dp"/>

    <!-- Apariencia -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Apariencia"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/haru_teal_dark"
        android:layout_marginBottom="10dp"/>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleTema"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTemaSistema"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sistema"
            android:textSize="12sp"
            android:textColor="@color/haru_teal_dark"
            app:strokeColor="@color/haru_teal"
            app:cornerRadius="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTemaClaro"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Claro"
            android:textSize="12sp"
            android:textColor="@color/haru_teal_dark"
            app:strokeColor="@color/haru_teal"
            app:cornerRadius="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTemaOscuro"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Oscuro"
            android:textSize="12sp"
            android:textColor="@color/haru_teal_dark"
            app:strokeColor="@color/haru_teal"
            app:cornerRadius="8dp"/>

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/haru_teal_light"
        android:layout_marginBottom="20dp"/>

    <!-- Cerrar sesión -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCerrarSesionPerfil"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerrar sesión"
        android:padding="12dp"
        android:textColor="#D32F2F"
        android:layout_marginBottom="8dp"
        app:strokeColor="#D32F2F"
        app:cornerRadius="12dp"/>

</LinearLayout>