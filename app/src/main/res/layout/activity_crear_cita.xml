<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/haru_surface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarCrearCita"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/haru_teal"
        app:title="Nueva cita"
        app:titleTextColor="@color/haru_white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/haru_white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Nombre de la mascota (solo informativo, viene por Intent) -->
            <TextView
                android:id="@+id/tvMascotaCrearCita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="23sp"
                android:textStyle="bold"
                android:textColor="@color/haru_brown"
                android:layout_marginBottom="24dp"/>

            <!-- Selector de veterinario: solo visible para CLINICA -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilVeterinario"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Veterinario"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:boxStrokeColor="@color/haru_teal"
                app:hintTextColor="@color/haru_teal_dark">

                <AutoCompleteTextView
                    android:id="@+id/actvVeterinario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:focusable="false"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Selector de mascota: solo visible para CLINICA -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilMascotaSelector"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mascota"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:boxStrokeColor="@color/haru_teal"
                app:hintTextColor="@color/haru_teal_dark">

                <AutoCompleteTextView
                    android:id="@+id/actvMascota"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:focusable="false"/>

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha y hora"
                android:textColor="@color/haru_teal_dark"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFechaHora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="8dp"
                app:strokeColor="@color/haru_teal"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <TextView
                    android:id="@+id/tvFechaHora"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Toca para seleccionar fecha y hora"
                    android:textColor="@color/haru_teal_dark"/>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilMotivo"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Motivo de la consulta"
                android:layout_marginBottom="32dp"
                app:boxStrokeColor="@color/haru_teal"
                app:hintTextColor="@color/haru_teal_dark">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMotivo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarCita"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar cita"
                android:padding="14dp"
                android:backgroundTint="@color/haru_teal"
                android:textColor="@color/haru_white"
                app:cornerRadius="12dp"/>

            <ProgressBar
                android:id="@+id/progressBarCita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:indeterminateTint="@color/haru_teal"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>