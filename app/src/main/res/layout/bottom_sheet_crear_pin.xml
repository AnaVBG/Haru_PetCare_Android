<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/haru_white">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"
        android:background="@color/haru_grey"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Añadir pin en mi ubicación"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/haru_brown"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvSubtituloCrearPin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="El pin se colocará donde estás ahora mismo"
        android:textSize="13sp"
        android:textColor="@color/haru_text_secondary"
        android:layout_marginBottom="20dp"/>

    <!-- Selector de tipo con ChipGroup -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tipo de punto"
        android:textSize="13sp"
        android:textColor="@color/haru_teal_dark"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupTipoPin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipFuente"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💧 Fuente"
            android:checked="true"
            app:chipBackgroundColor="@color/haru_teal_light"
            app:chipStrokeColor="@color/haru_teal"
            app:chipStrokeWidth="1dp"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPapelera"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗑️ Papelera"
            app:chipBackgroundColor="@color/haru_teal_light"
            app:chipStrokeColor="@color/haru_teal"
            app:chipStrokeWidth="1dp"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPeligro"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ Peligro"
            app:chipBackgroundColor="@color/haru_teal_light"
            app:chipStrokeColor="@color/haru_teal"
            app:chipStrokeWidth="1dp"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipParque"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌳 Parque"
            app:chipBackgroundColor="@color/haru_teal_light"
            app:chipStrokeColor="@color/haru_teal"
            app:chipStrokeWidth="1dp"/>

    </com.google.android.material.chip.ChipGroup>

    <!-- Descripción opcional -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilDescripcionPin"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Descripción (opcional)"
        android:layout_marginBottom="20dp"
        app:boxStrokeColor="@color/haru_teal"
        app:hintTextColor="@color/haru_teal_dark">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDescripcionPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:maxLines="3"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Botones -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCrearPin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Colocar pin"
        android:backgroundTint="@color/haru_teal"
        android:textColor="@color/haru_white"
        android:padding="14dp"
        app:cornerRadius="12dp"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelarPin"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancelar"
        android:textColor="@color/haru_text_secondary"/>

</LinearLayout>