<?xml version="1.0" encoding="utf-8"?>
<!--
    Android usa automáticamente esta carpeta cuando el sistema
    está en modo oscuro. Los nombres de los colores son los mismos
    que en values/colors.xml — solo cambian los valores.
-->
<resources>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- En modo oscuro el teal se aclara ligeramente para contrastar
         con el fondo oscuro y seguir siendo legible -->
    <color name="haru_teal">#5ECFCF</color>
    <color name="haru_teal_dark">#4BBFBF</color>
    <color name="haru_teal_light">#1A3333</color>

    <!-- El marrón se aclara para ser visible sobre fondo oscuro -->
    <color name="haru_brown">#D4735A</color>
    <color name="haru_brown_light">#C4937A</color>

    <!-- Fondos oscuros -->
    <color name="haru_white">#1E1E1E</color>
    <color name="haru_surface">#121212</color>

    <!-- Textos claros sobre fondo oscuro -->
    <color name="haru_grey">#666E6E</color>
    <color name="haru_text_primary">#E8E8E8</color>
    <color name="haru_text_secondary">#A0AAAA</color>
</resources>