<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- PERMISOS DE RED -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- PERMISOS DE UBICACIÓN (Dejamos listos para el futuro) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- PERMISOS DE NOTIFICACIONES -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HaruPetcare"
        android:usesCleartextTraffic="true"> <!-- CAMBIO 1: A true para que funcione tu IP local -->

        <!-- IMPORTANTE: He quitado android:name=".HaruApp" temporalmente.
             Si ya tienes esa clase creada, vuélvela a poner. Si no, la app crashea nada más abrir. -->

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false" />

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"> <!-- CAMBIO 2: A true. OBLIGATORIO para el MAIN/LAUNCHER -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false" />

        <!--
        ══════════════════════════════════════════════════════════════════════
        APAGADOS TEMPORALMENTE PARA LA PRIMERA REBANADA (LOGIN)
        Si dejas el servicio de FCM activo y la clase aún no existe, la app crashea.
        Descomenta esto cuando vayas a implementar los mapas y las notificaciones.
        ══════════════════════════════════════════════════════════════════════
        -->
        <!--
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="YOUR_MAPS_API_KEY" />

        <service
            android:name=".service.HaruFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        -->
    </application>
</manifest>